<?xml version="1.0" encoding="utf-8"?>
<androidx.wear.widget.BoxInsetLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="4dp"
        app:boxedEdges="all">

        <!-- Connection status -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tv_conn_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="●"
                android:textSize="10sp"
                android:textColor="@color/red" />

            <TextView
                android:id="@+id/tv_conn_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/disconnected"
                android:textSize="10sp"
                android:textColor="@color/red"
                android:fontFamily="monospace"
                android:layout_marginStart="4dp" />
        </LinearLayout>

        <!-- Target callsign -->
        <TextView
            android:id="@+id/tv_target"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/no_target"
            android:textSize="22sp"
            android:textColor="@color/cyan"
            android:fontFamily="monospace"
            android:layout_marginTop="8dp"
            android:gravity="center" />

        <!-- Target detail (tool + task) -->
        <TextView
            android:id="@+id/tv_target_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/dim_grey"
            android:fontFamily="monospace"
            android:gravity="center"
            android:maxLines="1"
            android:ellipsize="end" />

        <!-- Agent indicators row -->
        <LinearLayout
            android:id="@+id/ll_agents"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- Dispatch button -->
        <TextView
            android:id="@+id/tv_dispatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/tap_dispatch"
            android:textSize="11sp"
            android:textColor="@color/amber"
            android:fontFamily="monospace"
            android:layout_marginTop="12dp"
            android:gravity="center" />

        <!-- Settings hint -->
        <TextView
            android:id="@+id/tv_settings_hint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HOLD FOR SETTINGS"
            android:textSize="8sp"
            android:textColor="@color/dim_grey"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp" />
    </LinearLayout>
</androidx.wear.widget.BoxInsetLayout>
