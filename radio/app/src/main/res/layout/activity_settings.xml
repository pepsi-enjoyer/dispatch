<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPATCH RADIO"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SETTINGS"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="32dp" />

        <!-- Discover Console -->
        <Button
            android:id="@+id/btn_discover"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DISCOVER CONSOLE"
            android:textColor="@color/background"
            android:backgroundTint="@color/dim_grey"
            android:fontFamily="@font/share_tech_mono"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_discover_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/dim_grey"
            android:textSize="11sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="16dp" />

        <!-- Console Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CONSOLE ADDRESS"
            android:textColor="@color/dim_grey"
            android:textSize="11sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_host"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="192.168.1.1"
            android:inputType="textUri"
            android:textColor="@color/white"
            android:textColorHint="@color/dim_grey"
            android:background="@drawable/input_background"
            android:fontFamily="@font/share_tech_mono"
            android:padding="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Port -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PORT"
            android:textColor="@color/dim_grey"
            android:textSize="11sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="9800"
            android:inputType="number"
            android:textColor="@color/white"
            android:textColorHint="@color/dim_grey"
            android:background="@drawable/input_background"
            android:fontFamily="@font/share_tech_mono"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Pre-Shared Key -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PRE-SHARED KEY"
            android:textColor="@color/dim_grey"
            android:textSize="11sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_psk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="enter key from console"
            android:inputType="textPassword"
            android:textColor="@color/white"
            android:textColorHint="@color/dim_grey"
            android:background="@drawable/input_background"
            android:fontFamily="@font/share_tech_mono"
            android:padding="12dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_scan_qr"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SCAN QR CODE"
            android:textColor="@color/background"
            android:backgroundTint="@color/dim_grey"
            android:fontFamily="@font/share_tech_mono"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Speech Locale -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SPEECH RECOGNITION LOCALE"
            android:textColor="@color/dim_grey"
            android:textSize="11sp"
            android:fontFamily="@font/share_tech_mono"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/et_locale"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="en-US"
            android:inputType="text"
            android:textColor="@color/white"
            android:textColorHint="@color/dim_grey"
            android:background="@drawable/input_background"
            android:fontFamily="@font/share_tech_mono"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Toggles -->
        <CheckBox
            android:id="@+id/cb_haptic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HAPTIC FEEDBACK"
            android:textColor="@color/white"
            android:fontFamily="@font/share_tech_mono"
            android:buttonTint="@color/white"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cb_screen_on"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KEEP SCREEN ON"
            android:textColor="@color/white"
            android:fontFamily="@font/share_tech_mono"
            android:buttonTint="@color/white"
            android:layout_marginBottom="12dp" />

        <CheckBox
            android:id="@+id/cb_continuous"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONTINUOUS LISTENING (VAD)"
            android:textColor="@color/white"
            android:fontFamily="@font/share_tech_mono"
            android:buttonTint="@color/white"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_reset"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RESET TO DEFAULTS"
            android:textColor="@color/white"
            android:backgroundTint="@color/dim_grey"
            android:fontFamily="@font/share_tech_mono"
            android:textSize="12sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:textColor="@color/background"
            android:backgroundTint="@color/white"
            android:fontFamily="@font/share_tech_mono"
            android:textSize="14sp" />

    </LinearLayout>

</ScrollView>
